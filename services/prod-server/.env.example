# 生产服务器端口
PORT=3200

# 数据根目录（case JSON、图片、视频、配置等）
DATA_DIR=./apps/admin/public

# SP API 后端地址
SP_API_PORT=3100

# LLM 对话代理（训练端 /api/llm）
LLM_API_KEY=
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_MODEL=qwen-turbo

# AI 病例生成（管理端 /api/ai-generate）
AI_GENERATE_API_KEY=
AI_GENERATE_API_URL=https://api.openai.com/v1/chat/completions
AI_GENERATE_MODEL=gpt-4o
